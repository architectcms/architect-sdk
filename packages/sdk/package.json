{
  "name": "@architectcms/sdk",
  "version": "0.2.1",
  "description": "TypeScript SDK for Architect CMS — delivery, preview, and management clients",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "architect-sdk": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "architect",
    "cms",
    "sdk",
    "content",
    "delivery",
    "preview",
    "management",
    "headless"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/architectcms/architect-sdk.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/architectcms/architect-sdk/tree/main/packages/sdk#readme",
  "bugs": "https://github.com/architectcms/architect-sdk/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
